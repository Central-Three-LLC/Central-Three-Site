# ============================================================
# Central Three — public repo guardrails
# This repo is the PUBLIC marketing site ONLY.
# App source code, configs, and credentials belong in
# separate PRIVATE repositories. Never commit secrets here.
# ============================================================

# --- Environment & secrets ---
.env
.env.*
*.env
!.env.example
secrets.*
*secret*
*credentials*
config.json
settings.json

# --- Keys, certificates, identity ---
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
*.keystore
*.jks
*.mobileprovision
*.p8
id_rsa*
id_ed25519*
*.gpg
*.asc

# --- Cloud / service provider configs ---
.aws/
.gcloud/
.azure/
*.tfstate
*.tfstate.*
.netrc
.npmrc
.pypirc
firebase-debug.log
google-services.json
GoogleService-Info.plist
service-account*.json

# --- Tokens & auth artifacts ---
*.token
.auth
auth.json
.htpasswd

# --- Databases & dumps (often contain user data) ---
*.sql
*.sqlite
*.sqlite3
*.db
*.dump
*.bak

# --- Local junk ---
.DS_Store
Thumbs.db
desktop.ini
*.log
node_modules/
.cache/
.idea/
.vscode/
*.swp
